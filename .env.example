# Shopify Admin API Credentials
# Get these from: Shopify Admin → Apps → Develop apps → [Your App] → Configuration

# Your Shopify store name (without .myshopify.com)
# Example: my-awesome-store
SHOPIFY_STORE_NAME=

# API Key (also called Access Token in some contexts)
SHOPIFY_API_KEY=

# API Password (API access token from the private app)
SHOPIFY_API_PASSWORD=

# Backend Configuration
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
